{
  "name": "__MSG_name__",
  "version": "2.1.0",
  "description": "__MSG_description__",
  "options_page": "options.html",
  "background": {
    "service_worker": "background.bundle.js"
  },
  "permissions": [
    "webRequest",
    "activeTab",
    "tabs",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.bundle.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": "img/music128.png"
  },
  "icons": {
    "16" : "img/music16.png",
    "48" : "img/music48.png",
    "128": "img/music128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "img/music16.png",
        "img/music24.png",
        "img/music32.png",
        "img/music48.png",
        "img/arrowl32.png",
        "img/arrowr32.png",
        "img/m4a32.png",
        "img/aac32.png",
        "img/mp432.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "manifest_version": 3,
  "default_locale" : "zh_CN"
}
